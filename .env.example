# Database
#
# Local Docker Postgres (default for development):
DATABASE_URL=postgres://lovspeil:lovspeil@localhost:5432/lovspeil
#
# Neon Postgres (production):
# Copy the connection string from https://console.neon.tech
# DATABASE_URL=postgresql://user:password@ep-example-123456.eu-central-1.aws.neon.tech/neondb?sslmode=require
#
# For serverless deployments (Vercel etc.), prefer the pooled connection string
# from the Neon dashboard (host contains "-pooler"):
# DATABASE_URL=postgresql://user:password@ep-example-123456-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Public site URL (used for SEO, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://lovspeil.no
